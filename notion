#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "httpx",
# ]
# ///

import argparse
import json
import re
import sys
from pathlib import Path

import httpx

NOTION_VERSION = "2025-09-03"
CONFIG_PATH = Path.home() / ".config" / "notion-cli" / "config.json"
UUID_RE = re.compile(r"^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$")
HEX32_RE = re.compile(r"^[0-9a-fA-F]{32}$")


# ---------------------------------------------------------------------------
# Config helpers
# ---------------------------------------------------------------------------

def fail(message: str) -> None:
    print(message, file=sys.stderr)
    sys.exit(1)


def get_selected_profile(raw_profile: str) -> str:
    profile = raw_profile.strip()
    if not profile:
        fail("Profile cannot be empty.")
    return profile


def load_config(*, required: bool = True) -> dict:
    if not CONFIG_PATH.exists():
        if required:
            fail("No config found. Run `notion configure` first.")
        return {"profiles": {}}

    try:
        with CONFIG_PATH.open() as f:
            config = json.load(f)
    except json.JSONDecodeError:
        fail(f"Config file is malformed JSON: {CONFIG_PATH}. Please re-run `notion configure`.")

    if not isinstance(config, dict):
        fail(f"Invalid config format in {CONFIG_PATH}. Expected a JSON object.")

    profiles = config.get("profiles")
    if isinstance(profiles, dict):
        return config

    # Backward compatibility with the legacy single-profile format:
    # {"notion_secret": "secret_xxx"}
    legacy_secret = config.get("notion_secret")
    if isinstance(legacy_secret, str) and legacy_secret.strip():
        return {
            "profiles": {
                "default": {
                    "notion_secret": legacy_secret.strip(),
                }
            }
        }

    fail(f"Invalid config format in {CONFIG_PATH}. Expected top-level 'profiles' object.")


def save_config(config: dict) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with CONFIG_PATH.open("w") as f:
        json.dump(config, f, indent=2)
        f.write("\n")


def get_profile_secret(config: dict, profile: str) -> str:
    profile_data = config.get("profiles", {}).get(profile)
    if not isinstance(profile_data, dict):
        fail(f"Profile '{profile}' not configured. Run: notion configure -p {profile}")

    secret = profile_data.get("notion_secret")
    if not isinstance(secret, str) or not secret.strip():
        fail(f"Profile '{profile}' has no valid notion_secret. Re-run: notion configure -p {profile}")

    return secret.strip()


# ---------------------------------------------------------------------------
# Validation + parsing helpers
# ---------------------------------------------------------------------------

def normalize_notion_id(raw_id: str, object_label: str) -> str:
    value = raw_id.strip()
    if UUID_RE.fullmatch(value):
        return value.lower()

    if HEX32_RE.fullmatch(value):
        value = value.lower()
        return f"{value[0:8]}-{value[8:12]}-{value[12:16]}-{value[16:20]}-{value[20:32]}"

    fail(f"Invalid {object_label} ID: {raw_id}")


def parse_json_option(raw: str, expected_type: type, flag: str):
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError as e:
        fail(f"Invalid JSON for {flag}: {e}")

    if not isinstance(parsed, expected_type):
        expected = "array" if expected_type is list else "object"
        fail(f"Invalid {flag}: expected JSON {expected}.")

    return parsed


def validate_page_size(page_size: int | None) -> int | None:
    if page_size is None:
        return None
    if page_size < 1 or page_size > 100:
        fail("--page-size must be between 1 and 100.")
    return page_size


# ---------------------------------------------------------------------------
# HTTP helpers
# ---------------------------------------------------------------------------

def headers(secret: str) -> dict:
    return {
        "Authorization": f"Bearer {secret}",
        "Notion-Version": NOTION_VERSION,
        "Content-Type": "application/json",
    }


def notion_post(path: str, secret: str, body: dict) -> dict:
    url = f"https://api.notion.com{path}"
    resp = httpx.post(url, headers=headers(secret), json=body)
    if resp.status_code != 200:
        fail(f"Error {resp.status_code}: {resp.text}")
    return resp.json()


def notion_get(path: str, secret: str) -> dict:
    url = f"https://api.notion.com{path}"
    resp = httpx.get(url, headers=headers(secret))
    if resp.status_code != 200:
        fail(f"Error {resp.status_code}: {resp.text}")
    return resp.json()


def notion_patch(path: str, secret: str, body: dict) -> dict:
    url = f"https://api.notion.com{path}"
    resp = httpx.patch(url, headers=headers(secret), json=body)
    if resp.status_code != 200:
        fail(f"Error {resp.status_code}: {resp.text}")
    return resp.json()


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_configure(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config(required=False)

    existing_secret = config.get("profiles", {}).get(profile, {}).get("notion_secret")
    if isinstance(existing_secret, str) and existing_secret.strip():
        answer = input(f"Profile '{profile}' already exists. Reconfigure? [y/N] ").strip().lower()
        if answer != "y":
            print("Aborted.")
            return

    secret = input("Enter your Notion integration secret: ").strip()
    if not secret:
        fail("Secret cannot be empty.")

    config.setdefault("profiles", {})[profile] = {"notion_secret": secret}
    save_config(config)
    print(f"Config saved to {CONFIG_PATH} (profile: {profile})")


# ---------------------------------------------------------------------------
# Formatters
# ---------------------------------------------------------------------------

def extract_title(page: dict) -> str:
    """Extract plain-text title from a page, database, or data source result."""
    props = page.get("properties", {})
    if isinstance(props, dict):
        for prop in props.values():
            if isinstance(prop, dict) and prop.get("type") == "title":
                parts = prop.get("title", [])
                title = "".join(p.get("plain_text", "") for p in parts if isinstance(p, dict)).strip()
                if title:
                    return title

    title_list = page.get("title", [])
    if isinstance(title_list, list) and title_list:
        title = "".join(p.get("plain_text", "") for p in title_list if isinstance(p, dict)).strip()
        if title:
            return title

    name = page.get("name")
    if isinstance(name, str) and name.strip():
        return name.strip()

    return "(untitled)"


def extract_icon(page: dict) -> str:
    icon = page.get("icon")
    if icon and icon.get("type") == "emoji":
        return icon["emoji"] + " "
    return ""


def format_parent(parent: dict) -> str:
    if not parent:
        return "unknown"
    ptype = parent.get("type", "unknown")
    if ptype == "workspace":
        return "workspace"
    if ptype == "page_id":
        return f"page `{parent['page_id']}`"
    if ptype == "database_id":
        return f"database `{parent['database_id']}`"
    if ptype == "data_source_id":
        return f"data_source `{parent['data_source_id']}`"
    return ptype


def render_metadata_block(meta_lines: list[str]) -> str:
    return "<!-- metadata\n" + "\n".join(meta_lines) + "\n-->"


def print_pretty_json(data: dict) -> None:
    print(json.dumps(data, indent=2, ensure_ascii=False))


def format_search_result(page: dict) -> str:
    icon = extract_icon(page)
    title = extract_title(page)
    obj_type = page.get("object", "page")
    url = page.get("url", "")
    parent = format_parent(page.get("parent", {}))
    created = page.get("created_time", "")
    edited = page.get("last_edited_time", "")

    lines = [
        f"## {icon}{title}",
        f"- **Type:** {obj_type}",
    ]
    if url:
        lines.append(f"- **URL:** {url}")
    lines.append(f"- **Parent:** {parent}")
    if created:
        lines.append(f"- **Created:** {created}")
    if edited:
        lines.append(f"- **Last edited:** {edited}")
    return "\n".join(lines)


def format_search_output(data: dict) -> str:
    results = data.get("results", [])
    sections = [format_search_result(r) for r in results]
    body = "\n\n".join(sections) if sections else "_No results._"

    meta_lines = []
    if data.get("has_more") is True:
        meta_lines.append("has_more: true")
    next_cursor = data.get("next_cursor")
    if next_cursor:
        meta_lines.append(f"next_cursor: {next_cursor}")
    request_id = data.get("request_id", "")
    if request_id:
        meta_lines.append(f"request_id: {request_id}")

    if meta_lines:
        return body + "\n\n---\n\n" + render_metadata_block(meta_lines)
    return body


def convert_notion_markdown(raw: str) -> str:
    raw = re.sub(r'<page url="([^"]+)">([^<]*)</page>', r'[\2](\1)', raw)
    raw = re.sub(r'<empty-block\s*/>', '', raw)
    raw = re.sub(r'\n{3,}', '\n\n', raw)
    return raw.strip()


def format_fetch_output(data: dict, page_meta: dict, slice_range: tuple[int, int] | None = None) -> str:
    icon = extract_icon(page_meta)
    title = extract_title(page_meta)
    url = page_meta.get("url", "")
    header_lines = [f"# {icon}{title}"]
    if url:
        header_lines.append(f"**URL:** {url}")
    header = "\n".join(header_lines)

    raw_md = data.get("markdown", "")
    body = convert_notion_markdown(raw_md)

    if slice_range is not None:
        start, end = slice_range
        body_lines = body.splitlines()
        body = "\n".join(body_lines[start:end])

    unknown = data.get("unknown_block_ids", [])
    meta_lines = [
        f"page_id: {data.get('id', '')}",
        f"truncated: {str(data.get('truncated', False)).lower()}",
        f"unknown_block_ids: {', '.join(unknown) if unknown else '[]'}",
        f"request_id: {data.get('request_id', '')}",
    ]
    if slice_range is not None:
        meta_lines.append(f"slice: {slice_range[0]}-{slice_range[1]}")

    return header + "\n\n" + body + "\n\n---\n\n" + render_metadata_block(meta_lines)


def format_update_page_output(update_data: dict, page_meta: dict, mode: str) -> str:
    title = extract_title(page_meta)
    url = page_meta.get("url", "")
    unknown = update_data.get("unknown_block_ids", [])

    lines = [
        "# ✅ Updated Page",
        f"- **Title:** {title}",
        f"- **URL:** {url}",
        f"- **Page ID:** {update_data.get('id', page_meta.get('id', ''))}",
        f"- **Mode:** {mode}",
        f"- **Truncated:** {str(update_data.get('truncated', False)).lower()}",
        f"- **Unknown block IDs:** {', '.join(unknown) if unknown else '[]'}",
    ]

    meta_lines = [
        f"page_id: {update_data.get('id', page_meta.get('id', ''))}",
        f"mode: {mode}",
        f"truncated: {str(update_data.get('truncated', False)).lower()}",
        f"unknown_block_ids: {', '.join(unknown) if unknown else '[]'}",
    ]
    request_id = update_data.get("request_id", "")
    if request_id:
        meta_lines.append(f"request_id: {request_id}")

    return "\n".join(lines) + "\n\n---\n\n" + render_metadata_block(meta_lines)


def format_create_page_output(page_data: dict) -> str:
    title = extract_title(page_data)
    url = page_data.get("url", "")
    page_id = page_data.get("id", "")
    parent = format_parent(page_data.get("parent", {}))
    created = page_data.get("created_time", "")
    edited = page_data.get("last_edited_time", "")

    lines = [
        "# ✅ Created Page",
        f"- **Title:** {title}",
        f"- **URL:** {url}",
        f"- **Page ID:** {page_id}",
        f"- **Parent:** {parent}",
    ]
    if created:
        lines.append(f"- **Created:** {created}")
    if edited:
        lines.append(f"- **Last edited:** {edited}")

    parent_data = page_data.get("parent", {})
    if parent_data.get("type") == "page_id":
        parent_meta = f"parent: page_id:{parent_data.get('page_id', '')}"
    else:
        parent_meta = f"parent: {parent_data.get('type', 'unknown')}"

    meta_lines = [
        f"page_id: {page_id}",
        parent_meta,
    ]
    request_id = page_data.get("request_id", "")
    if request_id:
        meta_lines.append(f"request_id: {request_id}")

    return "\n".join(lines) + "\n\n---\n\n" + render_metadata_block(meta_lines)


# ---------------------------------------------------------------------------
# Argument parsing helpers
# ---------------------------------------------------------------------------

def parse_slice(value: str) -> tuple[int, int]:
    parts = value.split("-")
    if len(parts) != 2:
        raise argparse.ArgumentTypeError(f"--slice must be in the form N-M, got: {value!r}")
    try:
        start, end = int(parts[0]), int(parts[1])
    except ValueError:
        raise argparse.ArgumentTypeError(f"--slice values must be integers, got: {value!r}")
    if start < 0 or end < start:
        raise argparse.ArgumentTypeError(f"--slice requires 0 <= N <= M, got: {value!r}")
    return (start, end)


def read_replace_content(args) -> str:
    if args.content is not None and args.content_file is not None:
        fail("Use only one of --content or --content-file.")

    if args.content is not None:
        return args.content

    if args.content_file is not None:
        path = Path(args.content_file)
        try:
            return path.read_text(encoding="utf-8")
        except OSError as e:
            fail(f"Unable to read --content-file {path}: {e}")

    if sys.stdin.isatty():
        fail("Replace mode requires --content, --content-file, or piped stdin.")

    content = sys.stdin.read()
    if content == "":
        fail("Replace mode requires --content, --content-file, or piped stdin.")
    return content


def read_create_content(args) -> str | None:
    if args.content is not None and args.content_file is not None:
        fail("Use only one of --content or --content-file.")

    if args.content is not None:
        return args.content

    if args.content_file is not None:
        path = Path(args.content_file)
        try:
            return path.read_text(encoding="utf-8")
        except OSError as e:
            fail(f"Unable to read --content-file {path}: {e}")

    if sys.stdin.isatty():
        return None

    content = sys.stdin.read()
    if content == "":
        return None
    return content


def build_create_page_parent(args) -> dict:
    if not args.parent_page_id:
        fail("create-page requires --parent-page-id.")
    return {
        "type": "page_id",
        "page_id": normalize_notion_id(args.parent_page_id, "page"),
    }


def build_create_page_body(args) -> dict:
    title = args.title.strip()
    if not title:
        fail("Title cannot be empty.")

    body: dict = {
        "parent": build_create_page_parent(args),
        "properties": {
            "title": {
                "title": [
                    {
                        "text": {
                            "content": title,
                        }
                    }
                ]
            }
        },
    }

    content = read_create_content(args)
    if content is not None:
        body["markdown"] = content

    return body


def build_update_page_body(args) -> tuple[str, dict]:
    if args.replace:
        if args.old or args.new:
            fail("Do not mix --replace with --old/--new.")

        content = read_replace_content(args)
        body: dict = {
            "type": "replace_content",
            "replace_content": {
                "new_str": content,
            },
        }
        if args.allow_deleting_content:
            body["replace_content"]["allow_deleting_content"] = True
        return ("replace_content", body)

    if args.content is not None or args.content_file is not None:
        fail("--content and --content-file are only valid with --replace.")

    if len(args.old) != len(args.new):
        fail("--old and --new must be provided the same number of times.")
    if not args.old:
        fail("Update mode requires at least one --old/--new pair, or use --replace.")

    content_updates = []
    for old_str, new_str in zip(args.old, args.new):
        update: dict = {
            "old_str": old_str,
            "new_str": new_str,
        }
        if args.replace_all_matches:
            update["replace_all_matches"] = True
        content_updates.append(update)

    body = {
        "type": "update_content",
        "update_content": {
            "content_updates": content_updates,
        },
    }
    if args.allow_deleting_content:
        body["update_content"]["allow_deleting_content"] = True
    return ("update_content", body)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_search(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    body: dict = {}

    if args.query:
        body["query"] = args.query

    if args.sort_timestamp or args.sort_direction:
        body["sort"] = {
            "timestamp": args.sort_timestamp or "last_edited_time",
            "direction": args.sort_direction or "descending",
        }

    if args.start_cursor:
        body["start_cursor"] = args.start_cursor

    page_size = validate_page_size(args.page_size)
    if page_size is not None:
        body["page_size"] = page_size

    result = notion_post("/v1/search", secret, body)
    print(format_search_output(result))


def cmd_fetch_page(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    page_id = normalize_notion_id(args.page_id, "page")
    page_meta = notion_get(f"/v1/pages/{page_id}", secret)
    data = notion_get(f"/v1/pages/{page_id}/markdown", secret)

    slice_range = parse_slice(args.slice) if args.slice else None
    print(format_fetch_output(data, page_meta, slice_range))


def cmd_fetch_database(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    database_id = normalize_notion_id(args.database_id, "database")
    data = notion_get(f"/v1/databases/{database_id}", secret)
    print_pretty_json(data)


def cmd_fetch_data_source(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    data_source_id = normalize_notion_id(args.data_source_id, "data source")
    data = notion_get(f"/v1/data_sources/{data_source_id}", secret)
    print_pretty_json(data)


def cmd_query_data_source(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    data_source_id = normalize_notion_id(args.data_source_id, "data source")
    payload: dict = {}

    if args.sorts is not None:
        payload["sorts"] = parse_json_option(args.sorts, list, "--sorts")

    if args.filter is not None:
        payload["filter"] = parse_json_option(args.filter, dict, "--filter")

    if args.start_cursor:
        payload["start_cursor"] = args.start_cursor

    page_size = validate_page_size(args.page_size)
    if page_size is not None:
        payload["page_size"] = page_size

    if args.in_trash:
        payload["in_trash"] = True

    if args.result_type:
        payload["result_type"] = args.result_type

    resp = notion_post(f"/v1/data_sources/{data_source_id}/query", secret, payload)
    print_pretty_json(resp)


def cmd_update_page(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    page_id = normalize_notion_id(args.page_id, "page")
    mode, body = build_update_page_body(args)
    update_data = notion_patch(f"/v1/pages/{page_id}/markdown", secret, body)
    page_meta = notion_get(f"/v1/pages/{page_id}", secret)
    print(format_update_page_output(update_data, page_meta, mode))


def cmd_create_page(args) -> None:
    profile = get_selected_profile(args.profile)
    config = load_config()
    secret = get_profile_secret(config, profile)

    page_data = notion_post("/v1/pages", secret, build_create_page_body(args))
    print(format_create_page_output(page_data))


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def add_profile_argument(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "-p",
        "--profile",
        default="default",
        metavar="PROFILE",
        help="Config profile to use (default: default).",
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="notion",
        description="Lightweight Notion CLI for searching, reading, creating, and updating pages, databases, and data sources.",
    )
    add_profile_argument(parser)
    sub = parser.add_subparsers(dest="command", metavar="<command>")

    sub.add_parser(
        "configure",
        help="Set up or update your Notion integration secret.",
    )

    search_p = sub.add_parser(
        "search",
        help="Search Notion pages, databases, and data sources.",
    )
    search_p.add_argument(
        "query",
        nargs="?",
        default=None,
        help="Search query string.",
    )
    search_p.add_argument(
        "--sort-timestamp",
        default="last_edited_time",
        metavar="FIELD",
        help="Timestamp field to sort by (default: last_edited_time).",
    )
    search_p.add_argument(
        "--sort-direction",
        default="descending",
        choices=["ascending", "descending"],
        help="Sort direction (default: descending).",
    )
    search_p.add_argument(
        "--start-cursor",
        default=None,
        metavar="UUID",
        help="Pagination cursor (UUID) from a previous response.",
    )
    search_p.add_argument(
        "--page-size",
        type=int,
        default=10,
        metavar="N",
        help="Number of results to return, max 100 (default: 10).",
    )

    fetch_p = sub.add_parser(
        "fetch-page",
        help="Fetch a Notion page as Markdown.",
    )
    fetch_p.add_argument(
        "page_id",
        help="The UUID of the Notion page to fetch.",
    )
    fetch_p.add_argument(
        "--slice",
        default=None,
        metavar="N-M",
        help="Output only lines N through M of the page body (0-indexed, e.g. --slice 0-20).",
    )

    fetch_db_p = sub.add_parser(
        "fetch-database",
        help="Fetch a Notion database and print formatted JSON.",
    )
    fetch_db_p.add_argument(
        "database_id",
        help="The UUID of the Notion database to fetch.",
    )

    fetch_ds_p = sub.add_parser(
        "fetch-data-source",
        help="Fetch a Notion data source and print formatted JSON.",
    )
    fetch_ds_p.add_argument(
        "data_source_id",
        help="The UUID of the Notion data source to fetch.",
    )

    query_ds_p = sub.add_parser(
        "query-data-source",
        help="Query a Notion data source and print formatted JSON.",
    )
    query_ds_p.add_argument(
        "data_source_id",
        help="The UUID of the Notion data source to query.",
    )
    query_ds_p.add_argument(
        "--sorts",
        default=None,
        metavar="JSON",
        help="JSON array for Notion query sorts.",
    )
    query_ds_p.add_argument(
        "--filter",
        default=None,
        metavar="JSON",
        help="JSON object for Notion query filter.",
    )
    query_ds_p.add_argument(
        "--start-cursor",
        default=None,
        metavar="UUID",
        help="Pagination cursor (UUID) from a previous response.",
    )
    query_ds_p.add_argument(
        "--page-size",
        type=int,
        default=10,
        metavar="N",
        help="Number of results to return, max 100 (default: 10).",
    )
    query_ds_p.add_argument(
        "--in-trash",
        action="store_true",
        help="Include trashed entries.",
    )
    query_ds_p.add_argument(
        "--result-type",
        default=None,
        metavar="TYPE",
        help="Optional Notion result_type filter.",
    )

    create_p = sub.add_parser(
        "create-page",
